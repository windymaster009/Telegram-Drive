# Public local API URL. This must match backend TELEGRAM_DRIVE_API_HOST/PORT.
VITE_API_BASE_URL=http://localhost:14201

# Public Google OAuth client ID used to start browser/desktop login.
# Do not put GOOGLE_OAUTH_CLIENT_SECRET in frontend env files.
VITE_GOOGLE_OAUTH_CLIENT_ID=<google-oauth-client-id>

# Must match backend GOOGLE_OAUTH_REDIRECT_URI for local development.
VITE_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:1420/auth/google/callback
