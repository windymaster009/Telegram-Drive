# Local API host/port used by the standalone backend and embedded Tauri server.
TELEGRAM_DRIVE_API_HOST=127.0.0.1
TELEGRAM_DRIVE_API_PORT=14201

# Public HTTPS URL used when this backend is behind Nginx/Cloudflare.
# Required for Google OAuth callbacks and generated QR/login links in production.
# Leave empty for local-only development.
# TELEGRAM_DRIVE_PUBLIC_API_BASE_URL=https://api.example.com

# Local backend data directory. Relative paths are resolved from backend/.
# Stores encrypted Telegram session data and local keys.
TELEGRAM_DRIVE_DATA_DIR=.data

# Safety pacing for Telegram uploads. Higher values are gentler.
TELEGRAM_DRIVE_UPLOAD_DELAY_MS=12000

# MongoDB persistence for users, sessions, folder metadata, permissions, QR tokens, secrets, and audit logs.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?appName=<app-name>
MONGODB_DB_NAME=telegram_drive

# Long random secret for JWT sessions. Generate your own value for production.
JWT_SECRET=<generate-a-long-random-secret>

# Required. Stable 32-byte key used to encrypt/decrypt Telegram session storage.
# Use a 32-byte base64 or hex key and do not rotate it unless you recreate the owner session.
TELEGRAM_SESSION_ENCRYPTION_KEY=<32-byte-base64-or-hex-key>

# Google OAuth. The client secret must stay backend-only.
GOOGLE_OAUTH_CLIENT_ID=<google-oauth-client-id>
GOOGLE_OAUTH_CLIENT_SECRET=<google-oauth-client-secret>
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:1420/auth/google/callback

# Optional owner Telegram API credentials seed.
# These are read on startup and stored encrypted in MongoDB/local secret storage.
# You can also configure owner credentials through the admin UI.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional aliases supported by the backend for compatibility.
# APP_API_ID=
# APP_API_HASH=
