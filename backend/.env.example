TELEGRAM_DRIVE_API_HOST=127.0.0.1
TELEGRAM_DRIVE_API_PORT=14201
TELEGRAM_DRIVE_DATA_DIR=.data
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?appName=<app-name>
