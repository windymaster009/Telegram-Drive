GOOGLE_OAUTH_CLIENT_SECRET=<google-oauth-client-secret>
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:1420/auth/google/callback
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
